# =========================
# Backend runtime
# =========================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
API_AUTH_TOKEN=

# development | production
ENVIRONMENT=development

# Must stay false in production
ALLOW_INSECURE_SSL=false
SUPABASE_CA_BUNDLE=

# Optional: direct Postgres / schema access
SUPABASE_DB_URL=
SUPABASE_DB_PASSWORD=

# Optional: Supabase CLI / Management API token
SUPABASE_ACCESS_TOKEN=

# =========================
# LLM providers
# =========================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

AGNES_API_KEY=
# If Agnes gives you the full chat completions endpoint, fill AGNES_API_URL
AGNES_API_URL=
# If Agnes gives you only a base URL, fill AGNES_BASE_URL
# The app will append /v1/chat/completions automatically
AGNES_BASE_URL=
AGNES_MODEL=agnes-2.0-flash

# =========================
# Search providers
# =========================
TAVILY_API_KEY=
SERPAPI_API_KEY=

# Firecrawl Hosted API
# Hosted API base URL, not localhost
FIRECRAWL_BASE_URL=https://api.firecrawl.dev
FIRECRAWL_API_KEY=
SEARCH_PROVIDER=firecrawl

# =========================
# Frontend public env
# =========================
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# =========================
# Notes
# =========================
# Frontend must never use service_role key.
# Production must not set ALLOW_INSECURE_SSL=true
